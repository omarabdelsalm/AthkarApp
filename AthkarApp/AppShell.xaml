<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:AthkarApp.Views"
       x:Class="AthkarApp.AppShell"
       FlowDirection="RightToLeft">

    <TabBar>
        <Tab Title="الأذكار" Icon="athkar_icon.jpg">
            <ShellContent ContentTemplate="{DataTemplate views:AthkarPage}"/>
        </Tab>

        <Tab Title="مواقييت الصلاة" Icon="quran_icon.jpg">
            <ShellContent ContentTemplate="{DataTemplate views:PrayerPage}"/>
        </Tab>

        <Tab Title="المسبحة" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:TasbeehPage}"/>
        </Tab>

        <Tab Title="المصحف" Icon="quran_icon.jpg">
            <ShellContent ContentTemplate="{DataTemplate views:MushafPage}"/>
        </Tab>

        <Tab Title="الختمة" Icon="athkar_icon.jpg">
            <ShellContent ContentTemplate="{DataTemplate views:KhatmahPage}"/>
        </Tab>

        <Tab Title="الفهرس" Icon="quran_icon.jpg">
            <ShellContent ContentTemplate="{DataTemplate views:QuranPage}"/>
        </Tab>

        <Tab Title="راديو مباشر" Icon="athkar_icon.jpg">
            <ShellContent ContentTemplate="{DataTemplate views:LiveRadioPage}"/>
        </Tab>
    </TabBar>

</Shell>