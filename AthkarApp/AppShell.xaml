<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:AthkarApp.Views"
       x:Class="AthkarApp.AppShell"
       FlowDirection="RightToLeft">

    <TabBar>
        <Tab Title="الأذكار" Icon="athkar_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:AthkarPage}"/>
        </Tab>

        <Tab Title="المصحف" Icon="quran_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:MushafPage}"/>
        </Tab>

        <Tab Title="الفهرس" Icon="quran_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:QuranPage}"/>
        </Tab>
    </TabBar>

</Shell>