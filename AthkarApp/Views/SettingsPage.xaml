<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AthkarApp.Views.SettingsPage"
             Title="إعدادات الأصوات"
             BackgroundColor="#E8F0F8"
             FlowDirection="RightToLeft">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            
            <!-- إعدادات القارئ المفضل -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="إعدادات تلاوة القرآن" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#2C6E2C" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,5"/>

                    <Label Text="اختر القارئ المفضل لتلاوة الآيات والسور:" 
                           FontSize="14" 
                           TextColor="#666666" 
                           HorizontalOptions="Center"
                           Margin="0,0,0,5"/>

                    <Picker x:Name="ReciterPicker" 
                            Title="اختر القارئ" 
                            ItemDisplayBinding="{Binding Name}"
                            TextColor="#333333"
                            SelectedIndexChanged="OnReciterChanged" />

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5"/>

                    <Button Text="مسح كافة التنزيلات (توفير مساحة)" 
                            BackgroundColor="#FF5252" 
                            TextColor="White" 
                            CornerRadius="10"
                            FontSize="14"
                            Clicked="OnClearDownloadsClicked" />

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5"/>

                    <Label Text="صوت الأذان المفضل" FontSize="14" TextColor="#666666" Margin="0,5,0,0"/>
                    <Picker x:Name="AdhanPicker" 
                            Title="اختر صوت الأذان"
                            SelectedIndexChanged="OnAdhanSelected"
                            BackgroundColor="#F9F9F9"
                            TextColor="#2C6E2C" />

                    <Button Text="تجربة صوت الأذان 🔊" 
                            BackgroundColor="#D4AF37" 
                            TextColor="Black" 
                            CornerRadius="10"
                            FontSize="14"
                            Clicked="OnPreviewAdhan" />
                </VerticalStackLayout>
            </Frame>

            <!-- إعدادات مواقيت الصلاة -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="إعدادات مواقيت الصلاة" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#2C6E2C" 
                           HorizontalOptions="Center" />

                    <Label Text="طريقة حساب المواقيت" FontSize="14" TextColor="#666666" Margin="0,5,0,0"/>
                    <Picker x:Name="CalculationMethodPicker" 
                            Title="اختر طريقة الحساب"
                            SelectedIndexChanged="OnCalculationSettingChanged"
                            BackgroundColor="#F9F9F9"
                            TextColor="#333333" />

                    <Label Text="المذهب الفقهي (لصلاة العصر)" FontSize="14" TextColor="#666666" Margin="0,5,0,0"/>
                    <Picker x:Name="MadhabPicker" 
                            Title="اختر المذهب"
                            SelectedIndexChanged="OnCalculationSettingChanged"
                            BackgroundColor="#F9F9F9"
                            TextColor="#333333" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="تخصيص أصوات التنبيه" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#2C6E2C" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,10"/>
                    
                    <Label Text="اختر الأصوات التي ترغب في سماعها بالتناوب:" 
                           FontSize="14" 
                           TextColor="#666666" 
                           HorizontalOptions="Center"
                           Margin="0,0,0,20"/>

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>

                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="5">
                        <Label Text="صوت 1 (ان الله وملائكته يصلون)" VerticalOptions="Center" FontSize="18" TextColor="#333333"/>
                        <Button Grid.Column="1" Text="▶" 
                                BackgroundColor="Transparent" TextColor="#2C6E2C" FontSize="20"
                                Clicked="OnPreviewOm" Margin="10,0"/>
                        <Switch Grid.Column="2" x:Name="SwitchOm" IsToggled="True" OnColor="#2C6E2C" Toggled="OnSoundToggled"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>

                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="5">
                        <Label Text="صوت 2 (اللهم صل على محمد)" VerticalOptions="Center" FontSize="18" TextColor="#333333"/>
                        <Button Grid.Column="1" Text="▶" 
                                BackgroundColor="Transparent" TextColor="#2C6E2C" FontSize="20"
                                Clicked="OnPreviewAh" Margin="10,0"/>
                        <Switch Grid.Column="2" x:Name="SwitchAh" IsToggled="True" OnColor="#2C6E2C" Toggled="OnSoundToggled"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>

                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="5">
                        <Label Text="صوت 3 (صل على محمد)" VerticalOptions="Center" FontSize="18" TextColor="#333333"/>
                        <Button Grid.Column="1" Text="▶" 
                                BackgroundColor="Transparent" TextColor="#2C6E2C" FontSize="20"
                                Clicked="OnPreviewMa" Margin="10,0"/>
                        <Switch Grid.Column="2" x:Name="SwitchMa" IsToggled="True" OnColor="#2C6E2C" Toggled="OnSoundToggled"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="عن التطبيق" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#2C6E2C" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,10"/>
                    
                    <Button Text="📄 قراءة سياسة الخصوصية" 
                            BackgroundColor="#F9F9F9" 
                            TextColor="#333333" 
                            CornerRadius="10"
                            FontSize="15"
                            BorderColor="#CCCCCC"
                            BorderWidth="1"
                            Clicked="OnPrivacyPolicyClicked" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="سيتم تطبيق التغييرات فوراً على التنبيهات القادمة."
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,10"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
