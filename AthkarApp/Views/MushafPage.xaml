<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AthkarApp.Models"
             x:Class="AthkarApp.Views.MushafPage"
             x:Name="PageRoot"
             Title="المصحف الشريف"
             BackgroundColor="#F9F6F0"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ===== رأس الصفحة ===== -->
        <Frame Grid.Row="0"
               BackgroundColor="#2C6E2C"
               CornerRadius="0"
               Padding="12,10"
               HasShadow="True">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- اسم السورة الحالية -->
                <Label x:Name="CurrentSurahLabel"
                       Grid.Column="0"
                       Text="..."
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

                <!-- رقم الجزء والحزب -->
                <Label x:Name="JuzLabel"
                       Grid.Column="1"
                       Text=""
                       TextColor="#CCFFCC"
                       FontSize="12"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <!-- رقم الصفحة -->
                <HorizontalStackLayout Grid.Column="2"
                                       Spacing="2"
                                       VerticalOptions="Center">
                    <Entry x:Name="PageEntry"
                           Text="1"
                           TextColor="White"
                           Keyboard="Numeric"
                           WidthRequest="46"
                           HeightRequest="34"
                           HorizontalTextAlignment="Center"
                           FontSize="14"
                           Completed="OnPageEntryCompleted"/>
                    <Label Text="/ 604"
                           TextColor="#AAAAAA"
                           FontSize="12"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>
        </Frame>

        <!-- ===== شريط أزرار الأوضاع ===== -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              BackgroundColor="#EDE8DC"
              Padding="8,5">
            <Button Grid.Column="0"
                    x:Name="ScrollModeBtn"
                    Text="📜 وضع التمرير"
                    FontSize="12"
                    BackgroundColor="#2C6E2C"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnScrollModeClicked"
                    Margin="2"/>
            <Button Grid.Column="1"
                    x:Name="SwipeModeBtn"
                    Text="📖 وضع التقليب"
                    FontSize="12"
                    BackgroundColor="#A5A58D"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnSwipeModeClicked"
                    Margin="2"/>
        </Grid>

        <!-- ===== محتوى المصحف (وضع التمرير) ===== -->
        <RefreshView x:Name="ScrollModeView"
                     Grid.Row="2"
                     IsRefreshing="False"
                     IsVisible="True">
            <ScrollView>
                <VerticalStackLayout x:Name="AyahsContainer"
                                     Padding="15,8"
                                     Spacing="0">

                    <!-- عنوان السورة يُضاف برمجياً هنا -->
                    <Label x:Name="BismillahLabel"
                           Text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
                           FontSize="22"
                           TextColor="#2C6E2C"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,10,0,14"
                           IsVisible="False"/>

                    <CollectionView x:Name="AyahsCollectionView"
                                    SelectionMode="Single"
                                    SelectionChanged="OnAyahSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Ayah">
                                <Frame Padding="10,8"
                                       Margin="2,3"
                                       CornerRadius="10"
                                       HasShadow="False"
                                       BorderColor="#E0DDD5"
                                       BackgroundColor="White">
                                    <Label HorizontalTextAlignment="Center"
                                           HorizontalOptions="Center"
                                           TextColor="#1A3A1A"
                                           FontSize="22"
                                           LineBreakMode="WordWrap">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Text}" FontSize="22"/>
                                                <Span Text=" "/>
                                                <Span Text="{Binding NumberInSurah, StringFormat='﴿{0}﴾'}"
                                                      TextColor="#2C6E2C"
                                                      FontSize="15"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ===== محتوى المصحف (وضع التقليب) ===== -->
        <CarouselView x:Name="SwipeModeView"
                      Grid.Row="2"
                      IsVisible="False"
                      Loop="False"
                      PositionChanged="OnCarouselPositionChanged">
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="models:PageData">
                    <ScrollView>
                        <VerticalStackLayout Padding="15,10" Spacing="0">

                            <Label Text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
                                   IsVisible="{Binding HasBismillah}"
                                   FontSize="20"
                                   TextColor="#2C6E2C"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,8,0,10"/>

                            <CollectionView ItemsSource="{Binding Ayahs}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Ayah">
                                        <Frame Padding="10,8"
                                               Margin="2,3"
                                               CornerRadius="10"
                                               HasShadow="False"
                                               BorderColor="#E0DDD5"
                                               BackgroundColor="White">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.AyahTappedCommand, Source={x:Reference PageRoot}}"
                                                    CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>
                                            <Label HorizontalTextAlignment="Center"
                                                   HorizontalOptions="Center"
                                                   TextColor="#1A3A1A"
                                                   FontSize="22"
                                                   LineBreakMode="WordWrap">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Text}" FontSize="22"/>
                                                        <Span Text=" "/>
                                                        <Span Text="{Binding NumberInSurah, StringFormat='﴿{0}﴾'}"
                                                              TextColor="#2C6E2C"
                                                              FontSize="15"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </ScrollView>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- ===== لوحة التفسير (Bottom Sheet) ===== -->
        <Grid x:Name="TafsirOverlay"
              Grid.Row="0"
              Grid.RowSpan="4"
              IsVisible="False"
              BackgroundColor="#88000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTafsirOverlayTapped"/>
            </Grid.GestureRecognizers>

            <Frame x:Name="TafsirPanel"
                   BackgroundColor="White"
                   CornerRadius="24,24,0,0"
                   Padding="20,16"
                   HasShadow="True"
                   VerticalOptions="End"
                   Margin="0">
                <VerticalStackLayout Spacing="12">
                    <!-- مقبض -->
                    <BoxView WidthRequest="40"
                             HeightRequest="4"
                             Color="#CCCCCC"
                             CornerRadius="2"
                             HorizontalOptions="Center"/>

                    <!-- عنوان: رقم السورة والآية -->
                    <Label x:Name="TafsirAyahTitle"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#2C6E2C"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>

                    <!-- نص الآية -->
                    <Frame BackgroundColor="#F0FAF0"
                           CornerRadius="10"
                           Padding="12,8"
                           HasShadow="False"
                           BorderColor="#C8E6C9">
                        <Label x:Name="TafsirAyahText"
                               FontSize="20"
                               TextColor="#1A3A1A"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               HorizontalOptions="Center"/>
                    </Frame>

                    <!-- فاصل -->
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>

                    <!-- عنوان التفسير -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="📖"
                               FontSize="14"
                               VerticalOptions="Center"/>
                        <Label Text="تفسير الجلالين"
                               FontAttributes="Bold"
                               TextColor="#555555"
                               FontSize="14"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- نص التفسير -->
                    <ActivityIndicator x:Name="TafsirLoader"
                                       IsRunning="True"
                                       IsVisible="True"
                                       Color="#2C6E2C"
                                       HorizontalOptions="Center"/>

                    <ScrollView HeightRequest="150">
                        <Label x:Name="TafsirBodyLabel"
                               FontSize="15"
                               TextColor="#333333"
                               HorizontalTextAlignment="Start"
                               LineBreakMode="WordWrap"/>
                    </ScrollView>

                    <!-- زر الإغلاق -->
                    <Button Text="✕  إغلاق التفسير"
                            BackgroundColor="#2C6E2C"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="44"
                            Clicked="OnCloseTafsir"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- ===== أزرار التنقل ===== -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto,*"
              Padding="10,6"
              BackgroundColor="#EDE8DC">

            <Button Grid.Column="0"
                    x:Name="PrevButton"
                    Text="▶ السابقة"
                    BackgroundColor="#A5A58D"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="42"
                    Clicked="OnPrevPage"/>

            <Label Grid.Column="1"
                   x:Name="PageCounterLabel"
                   Text="1 / 604"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#555555"
                   FontSize="13"
                   Margin="12,0"/>

            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Text="◀ التالية"
                    BackgroundColor="#2C6E2C"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="42"
                    Clicked="OnNextPage"/>
        </Grid>

    </Grid>
</ContentPage>
