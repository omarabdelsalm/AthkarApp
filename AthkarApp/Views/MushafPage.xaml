<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AthkarApp.Models"
             x:Class="AthkarApp.Views.MushafPage"
             x:Name="PageRoot"
             Title="المصحف الشريف"
             BackgroundColor="#F9F6F0"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ===== رأس الصفحة ===== -->
        <Frame x:Name="HeaderUI"
               Grid.Row="0"
               BackgroundColor="#2C6E2C"
               CornerRadius="0"
               Padding="12,10"
               HasShadow="True">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label x:Name="CurrentSurahLabel"
                       Grid.Column="0"
                       Text="..."
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

                <Label x:Name="JuzLabel"
                       Grid.Column="1"
                       Text=""
                       TextColor="#CCFFCC"
                       FontSize="12"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <HorizontalStackLayout Grid.Column="2"
                                       Spacing="2"
                                       VerticalOptions="Center">
                    <Entry x:Name="PageEntry"
                           Text="1"
                           TextColor="White"
                           Keyboard="Numeric"
                           WidthRequest="46"
                           HeightRequest="34"
                           HorizontalTextAlignment="Center"
                           FontSize="14"
                           Completed="OnPageEntryCompleted"/>
                    <Label Text="/ 604"
                           TextColor="#AAAAAA"
                           FontSize="12"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>
        </Frame>

        <!-- ===== شريط أزرار الأوضاع ===== -->
        <Grid x:Name="ModeBarUI"
              Grid.Row="1"
              ColumnDefinitions="*,*"
              BackgroundColor="#EDE8DC"
              Padding="8,5">
            <Button Grid.Column="0"
                    x:Name="ScrollModeBtnCtrl"
                    Text="📜 وضع التمرير"
                    FontSize="12"
                    BackgroundColor="#2C6E2C"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnScrollModeClicked"
                    Margin="2"/>
            <Button Grid.Column="1"
                    x:Name="SwipeModeBtnCtrl"
                    Text="📖 وضع التقليب"
                    FontSize="12"
                    BackgroundColor="#A5A58D"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnSwipeModeClicked"
                    Margin="2"/>
        </Grid>

        <!-- ===== وضع التمرير ===== -->
        <CollectionView x:Name="AyahsCollectionView"
                        Grid.Row="2"
                        IsVisible="True"
                        SelectionMode="None">
            <CollectionView.Header>
                <VerticalStackLayout Padding="12,8">
                    <Label x:Name="BismillahLabel"
                           Text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
                           FontSize="22"
                           TextColor="#2C6E2C"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,10,0,14"
                           IsVisible="False"/>
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Ayah">
                    <Frame Padding="10,8"
                           Margin="14,3"
                           CornerRadius="10"
                           HasShadow="False"
                           BorderColor="#E0DDD5"
                           BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAyahTapped" CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <Label HorizontalTextAlignment="Center"
                               HorizontalOptions="Center"
                               TextColor="#1A3A1A"
                               FontSize="22"
                               LineBreakMode="WordWrap">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Text}" FontSize="22"/>
                                    <Span Text=" "/>
                                    <Span Text="{Binding NumberInSurah, StringFormat='﴿{0}﴾'}"
                                          TextColor="#2C6E2C"
                                          FontSize="15"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ===== وضع التقليب (CarouselView) ===== -->
        <CarouselView x:Name="SwipeModeView"
                      Grid.Row="2"
                      IsVisible="False"
                      Loop="False"
                      IsBounceEnabled="False"
                      PositionChanged="OnCarouselPositionChanged">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" SnapPointsType="MandatorySingle" SnapPointsAlignment="Center" />
            </CarouselView.ItemsLayout>
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="models:PageData">
                    <ScrollView>
                        <VerticalStackLayout Padding="12,8" Spacing="2">
                            <Label Text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
                                   IsVisible="{Binding HasBismillah}"
                                   FontSize="20"
                                   TextColor="#2C6E2C"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,8,0,10"/>

                            <CollectionView ItemsSource="{Binding Ayahs}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Ayah">
                                        <Frame Padding="10,8"
                                               Margin="2,3"
                                               CornerRadius="10"
                                               HasShadow="False"
                                               BorderColor="#E0DDD5"
                                               BackgroundColor="White">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnAyahTapped" CommandParameter="{Binding .}" />
                                            </Frame.GestureRecognizers>
                                            <Label HorizontalTextAlignment="Center"
                                                   HorizontalOptions="Center"
                                                   TextColor="#1A3A1A"
                                                   FontSize="22"
                                                   LineBreakMode="WordWrap">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Text}" FontSize="22"/>
                                                        <Span Text=" "/>
                                                        <Span Text="{Binding NumberInSurah, StringFormat='﴿{0}﴾'}"
                                                              TextColor="#2C6E2C"
                                                              FontSize="15"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- زر عائم للتبديل السريع لملء الشاشة بدون التأثير على الضغط على الآيات -->
        <Frame x:Name="FullscreenToggleBtn"
               Grid.Row="2"
               BackgroundColor="#AA2C6E2C"
               CornerRadius="25"
               Padding="0"
               Margin="15"
               HeightRequest="50"
               WidthRequest="50"
               HorizontalOptions="Start"
               VerticalOptions="End"
               HasShadow="False">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapScreen"/>
            </Frame.GestureRecognizers>
            <Label x:Name="FullscreenBtnLabel" 
                   Text="⤢" 
                   FontSize="22" 
                   TextColor="White" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"/>
        </Frame>

        <!-- ===== لوحة التفسير (Bottom Sheet) ===== -->
        <Grid x:Name="TafsirOverlay"
              Grid.Row="0"
              Grid.RowSpan="4"
              IsVisible="False"
              BackgroundColor="#88000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTafsirOverlayTapped"/>
            </Grid.GestureRecognizers>

            <!-- Border يدعم CornerRadius رباعي على عكس Frame -->
            <Border BackgroundColor="White"
                    VerticalOptions="End"
                    Margin="0"
                    Padding="20,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.3" Radius="20" Offset="0,-4"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <!-- منع إغلاق اللوحة عند النقر عليها -->
                    <TapGestureRecognizer Tapped="OnTafsirPanelTapped"/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="12">
                    <BoxView WidthRequest="40"
                             HeightRequest="4"
                             Color="#CCCCCC"
                             CornerRadius="2"
                             HorizontalOptions="Center"/>

                    <Label x:Name="TafsirAyahTitle"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#2C6E2C"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>

                    <Frame BackgroundColor="#F0FAF0"
                           CornerRadius="10"
                           Padding="12,8"
                           HasShadow="False"
                           BorderColor="#C8E6C9">
                        <Label x:Name="TafsirAyahText"
                               FontSize="20"
                               TextColor="#1A3A1A"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               HorizontalOptions="Center"/>
                    </Frame>

                    <BoxView HeightRequest="1" Color="#E0E0E0"/>

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="📖" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="تفسير الجلالين"
                               FontAttributes="Bold"
                               TextColor="#555555"
                               FontSize="14"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <ActivityIndicator x:Name="TafsirLoader"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#2C6E2C"
                                       HorizontalOptions="Center"/>

                    <ScrollView HeightRequest="150">
                        <Label x:Name="TafsirBodyLabel"
                               FontSize="15"
                               TextColor="#333333"
                               HorizontalTextAlignment="Start"
                               LineBreakMode="WordWrap"/>
                    </ScrollView>

                    <Button Text="✕  إغلاق التفسير"
                            BackgroundColor="#2C6E2C"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="44"
                            Clicked="OnCloseTafsir"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ===== أزرار التنقل ===== -->
        <Grid x:Name="FooterUI"
              Grid.Row="3"
              ColumnDefinitions="*,Auto,*"
              Padding="10,6"
              BackgroundColor="#EDE8DC">
            <Button Grid.Column="0"
                    x:Name="PrevButton"
                    Text="▶ السابقة"
                    BackgroundColor="#A5A58D"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="42"
                    Clicked="OnPrevPage"/>

            <Label Grid.Column="1"
                   x:Name="PageCounterLabel"
                   Text="1 / 604"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#555555"
                   FontSize="13"
                   Margin="12,0"/>

            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Text="◀ التالية"
                    BackgroundColor="#2C6E2C"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="42"
                    Clicked="OnNextPage"/>
        </Grid>

    </Grid>
</ContentPage>
