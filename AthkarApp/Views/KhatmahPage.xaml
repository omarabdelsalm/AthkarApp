<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AthkarApp.Views.KhatmahPage"
             Title="الختمة"
             BackgroundColor="#F9F6F0"
             FlowDirection="RightToLeft">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1B4D1B" Offset="0.1" />
            <GradientStop Color="#0D260D" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="15" Padding="0" StrokeShape="RoundRectangle 25" Stroke="#D4AF37" StrokeThickness="1" Background="{StaticResource HeaderGradient}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3" />
            </Border.Shadow>
            <VerticalStackLayout Padding="20" Spacing="5" HorizontalOptions="Center">
                <Label Text="متابعة الختمة" TextColor="#D4AF37" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center">
                    <Label.FontFamily>OpenSansSemibold</Label.FontFamily>
                </Label>
                <Label x:Name="StatusLabel" Text="لا توجد خطة حالية" TextColor="#E0E0E0" FontSize="15" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ActivePlanUI" Padding="15" Spacing="20" IsVisible="False">
                
                <!-- Main Progress Card -->
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 25" Padding="20" Stroke="Transparent">
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="0,5" Radius="15" Opacity="0.15" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="التقدم الإجمالي" FontSize="16" TextColor="#777" HorizontalOptions="Center"/>
                        <Grid HeightRequest="30">
                            <ProgressBar x:Name="KhatmahProgress" Progress="0.0" ProgressColor="#D4AF37" HeightRequest="12" VerticalOptions="Center"/>
                            <Label x:Name="ProgressPercentLabel" Text="0%" TextColor="#1B4D1B" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <Label x:Name="PagesReadLabel" Grid.Column="0" Text="المقروء: 0 صفحة" TextColor="#444" FontSize="13" FontAttributes="Bold"/>
                            <Label x:Name="PagesLeftLabel" Grid.Column="1" Text="المتبقي: 604" TextColor="#444" HorizontalOptions="End" FontSize="13" FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Current Position Card -->
                    <Border Grid.Column="0" BackgroundColor="#FDFCF9" StrokeShape="RoundRectangle 20" Padding="15" Stroke="#E8E3D5">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="أنت الآن 📍" FontSize="14" TextColor="#2C6E2C" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <BoxView HeightRequest="1" Color="#E8E3D5"/>
                            
                            <Label x:Name="CurrentSuraLabel" Text="..." FontSize="18" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center" FontFamily="Amiri-Regular"/>
                            
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label Text="ص" FontSize="12" TextColor="#777" VerticalOptions="Center"/>
                                <Label x:Name="CurrentPageLabel" Text="..." FontSize="16" FontAttributes="Bold" TextColor="#2C6E2C"/>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label Text="آية" FontSize="12" TextColor="#777" VerticalOptions="Center"/>
                                <Label x:Name="CurrentAyahLabel" Text="..." FontSize="16" FontAttributes="Bold" TextColor="#2C6E2C"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Today's Goal Card -->
                    <Border Grid.Column="1" BackgroundColor="#F6FFF6" StrokeShape="RoundRectangle 20" Padding="15" Stroke="#D4AF37">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="هدف اليوم 🎯" FontSize="14" TextColor="#143214" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <BoxView HeightRequest="1" Color="#E0F2E0"/>
                            
                            <Label x:Name="GoalSuraLabel" Text="..." FontSize="18" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center" FontFamily="Amiri-Regular"/>
                            
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label Text="إلى ص" FontSize="12" TextColor="#777" VerticalOptions="Center"/>
                                <Label x:Name="GoalPageLabel" Text="..." FontSize="16" FontAttributes="Bold" TextColor="#D4AF37"/>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label Text="آية" FontSize="12" TextColor="#777" VerticalOptions="Center"/>
                                <Label x:Name="GoalAyahLabel" Text="..." FontSize="16" FontAttributes="Bold" TextColor="#D4AF37"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Today's Portion Summary & Action -->
                <Border BackgroundColor="#143214" StrokeShape="RoundRectangle 20" Padding="20" Stroke="Transparent">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="TodayPortionSummaryLabel" Text="جاري حساب الورد..." TextColor="White" FontSize="15" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        
                        <Button Text="استكمال القراءة الآن" 
                                BackgroundColor="#D4AF37" 
                                TextColor="#143214" 
                                FontAttributes="Bold" 
                                CornerRadius="15" 
                                HeightRequest="55" 
                                Clicked="OnContinueReadingClicked">
                            <Button.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.3"/>
                            </Button.Shadow>
                        </Button>
                    </VerticalStackLayout>
                </Border>

                <Button Text="إلغاء الخطة الحالية" BackgroundColor="Transparent" TextColor="#A5A58D" CornerRadius="12" HeightRequest="40" Margin="0,5,0,10" Clicked="OnCancelPlanClicked"/>

            </VerticalStackLayout>

            <VerticalStackLayout x:Name="NewPlanUI" Padding="20" Spacing="25" IsVisible="True" VerticalOptions="Center">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="ابدأ رحلة الختمة 🕋" FontSize="26" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center"/>
                    <Label Text="اختر الخطة المناسبة لك للبدء" FontSize="16" TextColor="#666" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="White" Padding="5">
                    <VerticalStackLayout Spacing="10" Padding="15">
                        <Button Text="ختمة في 15 يوم (مكثفة)" BackgroundColor="#143214" TextColor="White" CornerRadius="15" HeightRequest="65" FontSize="17" Clicked="OnCreatePlan15"/>
                        <Button Text="ختمة في 30 يوم (شهرية)" BackgroundColor="#2C6E2C" TextColor="White" CornerRadius="15" HeightRequest="65" FontSize="17" Clicked="OnCreatePlan30"/>
                        <Button Text="ختمة في 60 يوم (ميسرة)" BackgroundColor="#4B634B" TextColor="White" CornerRadius="15" HeightRequest="65" FontSize="17" Clicked="OnCreatePlan60"/>
                    </VerticalStackLayout>
                </Border>
                
                <Label Text="* الخطة تعتمد على المصحف الورقي (604 صفحة)" FontSize="12" TextColor="#999" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
