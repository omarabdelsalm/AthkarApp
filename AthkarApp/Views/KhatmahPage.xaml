<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AthkarApp.Views.KhatmahPage"
             Title="الختمة"
             BackgroundColor="#F9F6F0"
             FlowDirection="RightToLeft">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1B4D1B" Offset="0.1" />
            <GradientStop Color="#0D260D" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="15" Padding="0" StrokeShape="RoundRectangle 25" Stroke="#D4AF37" StrokeThickness="1" Background="{StaticResource HeaderGradient}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3" />
            </Border.Shadow>
            <VerticalStackLayout Padding="20" Spacing="5" HorizontalOptions="Center">
                <Label Text="متابعة الختمة" TextColor="#D4AF37" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center">
                    <Label.FontFamily>OpenSansSemibold</Label.FontFamily>
                </Label>
                <Label x:Name="StatusLabel" Text="لا توجد خطة حالية" TextColor="#E0E0E0" FontSize="15" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <Grid>
                <VerticalStackLayout x:Name="ActivePlanUI" Padding="15" Spacing="25" IsVisible="False">
                
                <!-- Circular Progress Section -->
                <Grid HeightRequest="250" WidthRequest="250" HorizontalOptions="Center">
                    <Ellipse Stroke="#E8E3D5" StrokeThickness="15" WidthRequest="220" HeightRequest="220" HorizontalOptions="Center" VerticalOptions="Center"/>
                    
                    <!-- Simplified Progress Indicator (Using a stylized Border for now as MAUI Arcs require more complex drawing) -->
                    <Border BackgroundColor="Transparent" 
                            Stroke="#D4AF37" 
                            StrokeThickness="15" 
                            WidthRequest="220" 
                            HeightRequest="220" 
                            StrokeShape="Ellipse"
                            HorizontalOptions="Center" 
                            VerticalOptions="Center"
                            Opacity="0.8">
                        <Border.Shadow>
                            <Shadow Brush="#D4AF37" Offset="0,0" Radius="15" Opacity="0.5"/>
                        </Border.Shadow>
                    </Border>

                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                        <Label x:Name="ProgressPercentLabel" Text="0%" FontSize="44" FontAttributes="Bold" TextColor="#1B4D1B" HorizontalOptions="Center"/>
                        <Label Text="التقدم الإجمالي" FontSize="14" TextColor="#777" HorizontalOptions="Center"/>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,5">
                            <Label x:Name="PagesReadLabel" Text="0" TextColor="#2C6E2C" FontAttributes="Bold" FontSize="16"/>
                            <Label x:Name="PagesTotalLabel" Text="من 604 صفحة" TextColor="#777" FontSize="14"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- Stats Cards Row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <!-- Days Remaining -->
                    <Border Grid.Column="0" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 20" Stroke="Transparent">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.05" Radius="10" Offset="0,4"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🗓️ الأيام" FontSize="12" TextColor="#777" HorizontalOptions="Center"/>
                            <Label x:Name="DaysPassedLabel" Text="اليوم 1" FontSize="18" FontAttributes="Bold" TextColor="#1B4D1B" HorizontalOptions="Center"/>
                            <Label x:Name="TotalDaysLabel" Text="من 30" FontSize="11" TextColor="#999" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Pages Left -->
                    <Border Grid.Column="1" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 20" Stroke="Transparent">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.05" Radius="10" Offset="0,4"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="📖 المتبقي" FontSize="12" TextColor="#777" HorizontalOptions="Center"/>
                            <Label x:Name="PagesLeftLabel" Text="604" FontSize="18" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center"/>
                            <Label Text="صفحة" FontSize="11" TextColor="#999" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Location & Goal Grid -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <Border Grid.Column="0" BackgroundColor="#FDFCF9" StrokeShape="RoundRectangle 20" Padding="15" Stroke="#E8E3D5">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="مكانك الحالي 📍" FontSize="12" TextColor="#2C6E2C" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <Label x:Name="CurrentSuraLabel" Text="..." FontSize="16" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center" FontFamily="Amiri-Regular"/>
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="3">
                                <Label Text="صفحة" FontSize="12" TextColor="#777"/>
                                <Label x:Name="CurrentPageLabel" Text="..." FontSize="14" FontAttributes="Bold" TextColor="#2C6E2C"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#F6FFF6" StrokeShape="RoundRectangle 20" Padding="15" Stroke="#D4AF37">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="هدف اليوم 🎯" FontSize="12" TextColor="#143214" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <Label x:Name="GoalSuraLabel" Text="..." FontSize="16" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center" FontFamily="Amiri-Regular"/>
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="3">
                                <Label Text="إلى صفحة" FontSize="12" TextColor="#777"/>
                                <Label x:Name="GoalPageLabel" Text="..." FontSize="14" FontAttributes="Bold" TextColor="#D4AF37"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Bottom Status Card -->
                <Border BackgroundColor="#143214" StrokeShape="RoundRectangle 25" Padding="20" Stroke="Transparent">
                    <Border.Shadow>
                        <Shadow Brush="#143214" Opacity="0.3" Radius="15" Offset="0,6"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="15">
                        <Label x:Name="TodayPortionSummaryLabel" 
                               Text="جاري حساب الورد..." 
                               TextColor="White" 
                               FontSize="14" 
                               HorizontalOptions="Center" 
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>
                        
                        <Button Text="استكمال القراءة" 
                                BackgroundColor="#D4AF37" 
                                TextColor="#143214" 
                                FontAttributes="Bold" 
                                CornerRadius="18" 
                                HeightRequest="55" 
                                Clicked="OnContinueReadingClicked"/>
                    </VerticalStackLayout>
                </Border>

                <Button Text="إيقاف الخطة الحالية" 
                        BackgroundColor="Transparent" 
                        TextColor="#A5A58D" 
                        FontSize="13"
                        Clicked="OnCancelPlanClicked"
                        HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="NewPlanUI" Padding="20" Spacing="25" IsVisible="True" VerticalOptions="Center">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="ابدأ رحلة الختمة 🕋" FontSize="26" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center"/>
                    <Label Text="قم بإنشاء خطة مخصصة تناسب وقتك" FontSize="16" TextColor="#666" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <Border StrokeShape="RoundRectangle 25" BackgroundColor="White" Padding="20" Stroke="Transparent">
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="0,5" Radius="15" Opacity="0.1" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">
                        <Image Source="quran_icon.jpg" HeightRequest="150" Aspect="AspectFit"/>
                        <Button Text="إنشاء خطة ختمة جديدة" 
                                BackgroundColor="#143214" 
                                TextColor="White" 
                                CornerRadius="20" 
                                HeightRequest="65" 
                                FontSize="18" 
                                FontAttributes="Bold"
                                Clicked="OnOpenCreatePopupClicked"/>
                    </VerticalStackLayout>
                </Border>
                
                <Label Text="* يمكنك تخصيص المدة وكمية الورد اليومي" FontSize="12" TextColor="#999" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
