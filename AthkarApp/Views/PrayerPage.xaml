<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AthkarApp.Views.PrayerPage"
             Title="مواقيت الصلاة"
             BackgroundColor="#0B200B"
             FlowDirection="RightToLeft">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#143214" Offset="0.1" />
            <GradientStop Color="#1B4D1B" Offset="0.5" />
            <GradientStop Color="#2C6E2C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Premium Header Panel -->
        <Frame Grid.Row="0" Margin="15" Padding="0" CornerRadius="25" BorderColor="#D4AF37" HasShadow="True">
            <Grid HeightRequest="220" Background="{StaticResource HeaderGradient}">
                <!-- Pattern Background -->
                <Image Source="appicon.svg" Aspect="AspectFill" Opacity="0.05" Scale="2"/>
                
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                    <Label x:Name="NextPrayerLabel" Text="الصلاة القادمة: --" TextColor="#D4AF37" FontSize="18" HorizontalOptions="Center" FontAttributes="Bold"/>
                    <Label x:Name="CountdownLabel" Text="00:00:00" TextColor="White" FontSize="54" FontAttributes="Bold" HorizontalOptions="Center">
                        <Label.Shadow>
                            <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.5"/>
                        </Label.Shadow>
                    </Label>
                    <Label x:Name="HijriDateLabel" Text="-- رمضان ----" TextColor="#EEEEEE" FontSize="16" HorizontalOptions="Center" Margin="0,5,0,0"/>
                    
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="📍" FontSize="12"/>
                        <Label x:Name="LocationLabel" Text="جاري تحديد الموقع..." TextColor="#CCCCCC" FontSize="12" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="20">
                
                <!-- Prayer Timings Card -->
                <Frame BackgroundColor="#F5F5F5" CornerRadius="20" Padding="5" BorderColor="#D4AF37" HasShadow="True">
                    <VerticalStackLayout x:Name="TimingsList" Spacing="0">
                        <!-- Populated dynamically -->
                    </VerticalStackLayout>
                </Frame>

                <!-- Qibla Finder Card -->
                <Frame BackgroundColor="White" CornerRadius="25" Padding="25" HasShadow="True" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Label Text="بوصلة القبلة" FontSize="22" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center"/>
                        
                        <Grid HeightRequest="220" WidthRequest="220">
                            <!-- Premium Dial -->
                            <Image Source="compass_dial_premium.png" Aspect="AspectFit"/>
                            
                            <!-- Needle Container -->
                            <Grid x:Name="CompassContainer">
                                <!-- Golden Needle -->
                                <Image x:Name="QiblaNeedle" 
                                       Source="qibla_needle_gold.png" 
                                       HeightRequest="140" 
                                       WidthRequest="40" 
                                       VerticalOptions="Center" 
                                       HorizontalOptions="Center">
                                    <Image.Shadow>
                                        <Shadow Brush="Black" Offset="3,3" Radius="5" Opacity="0.4"/>
                                    </Image.Shadow>
                                </Image>
                            </Grid>

                            <!-- Center Cap -->
                            <Ellipse Fill="#D4AF37" HeightRequest="12" WidthRequest="12" VerticalOptions="Center" HorizontalOptions="Center">
                                <Ellipse.Shadow>
                                    <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.3"/>
                                </Ellipse.Shadow>
                            </Ellipse>
                        </Grid>
                        
                        <Frame BackgroundColor="#F0F9F0" CornerRadius="15" Padding="15,8" HorizontalOptions="Center" BorderColor="#D4AF37">
                            <Label x:Name="QiblaAngleLabel" Text="الزاوية: --" FontSize="16" TextColor="#143214" FontAttributes="Bold"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="تحديث البيانات يدويأ" 
                        Clicked="OnRefreshClicked" 
                        BackgroundColor="#D4AF37" 
                        TextColor="#143214"
                        FontAttributes="Bold"
                        CornerRadius="15" 
                        HeightRequest="50"
                        Margin="0,0,0,30"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
