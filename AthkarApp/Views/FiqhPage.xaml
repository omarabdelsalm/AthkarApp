<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AthkarApp.Models"
             x:Class="AthkarApp.Views.FiqhPage"
             Title="الفقه الميسر"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Background Overlay -->
        <BoxView Color="#F2F7F2" Grid.RowSpan="2" HorizontalOptions="Fill" VerticalOptions="Fill"/>
        <Image Source="athkar_icon.jpg" Grid.RowSpan="2" Aspect="AspectFill" Opacity="0.05"/>

        <Frame Grid.Row="0" Margin="15,10" Padding="0" CornerRadius="10" HasShadow="False" BackgroundColor="White" BorderColor="#E0E0E0">
            <SearchBar x:Name="FiqhSearch" 
                       Placeholder="ابحث عن حكم شرعي (صلاة، زكاة...)" 
                       TextChanged="OnSearchTextChanged"
                       CancelButtonColor="#00796B"
                       PlaceholderColor="Silver"
                       TextColor="#004D40"/>
        </Frame>

        <!-- Chapter Index (Quick Links) -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="10,0,10,10">
            <HorizontalStackLayout x:Name="IndexLayout" Spacing="8" Padding="5">
                <!-- Chips will be added here dynamically in code-behind -->
            </HorizontalStackLayout>
        </ScrollView>

        <CollectionView x:Name="ChaptersList" Grid.Row="2" IsGrouped="True">

            <CollectionView.Header>
                <VerticalStackLayout Padding="15,10" Spacing="5">
                    <Label Text="الفقه الميسر" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           TextColor="#00796B"
                           HorizontalOptions="Center"/>
                    <Label Text="أهم أحكام العبادات التي يحتاجها كل مسلم" 
                           FontSize="14" 
                           TextColor="Gray"
                           HorizontalOptions="Center"/>
                    <BoxView HeightRequest="2" Color="#00796B" Margin="20,10" Opacity="0.3"/>
                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- Chapter Header (Group Header) -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:FiqhChapter">
                    <Grid Padding="15,10,15,5">
                        <Frame BackgroundColor="#00796B" CornerRadius="10" Padding="12">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="{Binding Icon}" FontSize="20" VerticalOptions="Center"/>
                                <Label Text="{Binding Title}" 
                                       FontSize="18" 
                                       FontAttributes="Bold" 
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- Topic Template -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FiqhTopic">
                    <Grid Padding="20,5,20,10">
                        <Frame BackgroundColor="White" 
                               BorderColor="#E0E0E0" 
                               CornerRadius="15" 
                               Padding="20"
                               HasShadow="False">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Title}" 
                                       FontSize="18" 
                                       FontAttributes="Bold" 
                                       TextColor="#004D40"/>
                                
                                <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill"/>
                                
                                <Label Text="{Binding Content}" 
                                       FontSize="15" 
                                       LineHeight="1.5" 
                                       TextColor="#555555" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <VerticalStackLayout Padding="30" HorizontalOptions="Center">
                    <Label Text="« مَن يُرِدِ اللَّهُ بِهِ خَيْرًا يُفَقِّهْهُ فِي الدِّينِ »" 
                           TextColor="#00796B" 
                           FontSize="14" 
                           FontAttributes="Italic"/>
                </VerticalStackLayout>
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</ContentPage>
