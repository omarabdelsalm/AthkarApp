<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AthkarApp.Views.LiveRadioPage"
             Title="البث المباشر"
             BackgroundColor="#0B200B"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto, *">
        <!-- Player Area -->
        <Frame Grid.Row="0" Margin="10" Padding="0" CornerRadius="15" BackgroundColor="Black" HeightRequest="220" HasShadow="True">
            <Grid>
                <!-- Video/Audio Player -->
                <toolkit:MediaElement x:Name="MainPlayer"
                                      ShouldShowPlaybackControls="True"
                                      ShouldAutoPlay="False"
                                      HeightRequest="220"
                                      WidthRequest="300"
                                      HorizontalOptions="Fill" />
                
                <!-- Overlay for Audio-only to show a nice graphic -->
                <Grid x:Name="AudioOverlay" BackgroundColor="#1A3A1A" IsVisible="True">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                        <Label x:Name="PlayingTitleLabel" Text="اختر قناة للتشغيل" TextColor="#D4AF37" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="📻 جاري البث المباشر..." TextColor="White" FontSize="14" HorizontalOptions="Center"/>
                        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" Color="#D4AF37" Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Frame>

        <!-- Channels List -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="15">
                <Label Text="القنوات الإذاعية والتلفزيونية" TextColor="White" FontSize="18" FontAttributes="Bold" Margin="5,0,0,10"/>
                
                <CollectionView x:Name="ChannelsListView" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="#143214" BorderColor="#D4AF37" Padding="15" CornerRadius="12">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.PlayCommand}" CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="0" Text="{Binding Icon}" FontSize="24" VerticalOptions="Center" Margin="0,0,15,0"/>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                        <Label Text="{Binding Description}" TextColor="#CCCCCC" FontSize="12"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="▶" TextColor="#D4AF37" FontSize="20" VerticalOptions="Center"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout Padding="10" Margin="0,20">
                    <Label Text="ملاحظة: البث المباشر يتطلب اتصال إنترنت مستقر." 
                           TextColor="#888888" 
                           FontSize="12" 
                           HorizontalOptions="Center" 
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
