<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AthkarApp.Views.TasbeehPage"
             Title="المسبحة"
             BackgroundColor="#E8F0F8"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        
        <!-- الهيدر -->
        <VerticalStackLayout Grid.Row="0" Spacing="5" HorizontalOptions="Center" Margin="0,10,0,0">
             <Label Text="المسبحة الإلكترونية" 
                    FontSize="28" 
                    FontAttributes="Bold" 
                    TextColor="#2C6E2C" 
                    HorizontalOptions="Center"/>
             <Label Text="فَسَبِّحْ بِحَمْدِ رَبِّكَ وَاسْتَغْفِرْهُ" 
                    FontSize="16" 
                    TextColor="#666666" 
                    HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- منطقة العداد المركزية -->
        <Grid Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center">
            
            <!-- تأثير الظل والوهج الخلفي -->
            <Ellipse Fill="#C8E6C9" WidthRequest="280" HeightRequest="280" Opacity="0.3"/>
            
            <!-- زر التفاعل الرئيسي (الخرزة) -->
            <Frame x:Name="CounterFrame"
                   BackgroundColor="White" 
                   CornerRadius="130" 
                   WidthRequest="260" 
                   HeightRequest="260" 
                   Padding="0"
                   HasShadow="True"
                   BorderColor="#2C6E2C">
                
                <Grid>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="5">
                        <Label x:Name="CountLabel" 
                               Text="0" 
                               FontSize="72" 
                               FontAttributes="Bold" 
                               TextColor="#2C6E2C"
                               HorizontalOptions="Center"/>
                        <Label Text="اضغط للتسبيح" 
                               FontSize="14" 
                               TextColor="#999999"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    
                    <Button BackgroundColor="Transparent" 
                            Clicked="OnCounterClicked"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- الإحصائيات والأزرار السفلية -->
        <VerticalStackLayout Grid.Row="2" Spacing="20" Margin="0,0,0,20">
            
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="30">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="الإجمالي اليومي" FontSize="14" TextColor="#666666" HorizontalOptions="Center"/>
                    <Label x:Name="TotalLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="#2C6E2C" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <BoxView WidthRequest="1" Color="#CCCCCC" HeightRequest="40"/>
                
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="أفضل نتيجة" FontSize="14" TextColor="#666666" HorizontalOptions="Center"/>
                    <Label x:Name="BestLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="#2C6E2C" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                <Button Text="🔄 إعادة" 
                        BackgroundColor="#FF9800"
                        TextColor="White"
                        CornerRadius="25"
                        Padding="20,0"
                        HeightRequest="50"
                        Clicked="OnResetClicked"/>
                
                <Button x:Name="HapticBtn"
                        Text="📳 اهتزاز: مفعّل" 
                        BackgroundColor="#2C6E2C"
                        TextColor="White"
                        CornerRadius="25"
                        Padding="20,0"
                        HeightRequest="50"
                        Clicked="OnToggleHaptic"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
