<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AthkarApp.Views.AthkarPage"
             Title="الأذكار اليومية"
             BackgroundColor="#F5F5F5"
             FlowDirection="RightToLeft">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="CategoryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2C6E2C" Offset="0.1" />
            <GradientStop Color="#143214" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid>
        <!-- Category Selection View -->
        <ScrollView x:Name="SelectionView" IsVisible="True">
            <VerticalStackLayout Padding="15" Spacing="20">
                
                <!-- Welcome Header -->
                <Frame BackgroundColor="#143214" CornerRadius="20" Padding="15">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <!-- Settings Icon (Left side in RTL) -->
                        <ImageButton Source="settings_icon_premium.jpg"
                                     Grid.Column="0"
                                     WidthRequest="32"
                                     HeightRequest="32"
                                     BackgroundColor="Transparent"
                                     HorizontalOptions="Start"
                                     VerticalOptions="Center"
                                     Clicked="OnSettingsClicked">
                        </ImageButton>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="موسوعة الأذكار" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <Label Text="حافظ على أذكارك" TextColor="#D4AF37" FontSize="12" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Streak (Right side in RTL) -->
                        <HorizontalStackLayout Grid.Column="2" Spacing="5" VerticalOptions="Center" HorizontalOptions="End">
                            <Label Text="🔥" FontSize="18"/>
                            <Label x:Name="StreakLabel" Text="0" TextColor="#D4AF37" FontSize="20" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Frame>

                <CollectionView x:Name="CategoriesCollectionView" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="15" HorizontalItemSpacing="15"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" CornerRadius="20" Padding="0" HasShadow="True" HeightRequest="160" BorderColor="Transparent">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                                <Grid>
                                    <!-- Background Image -->
                                    <Image Source="{Binding ImagePath}" 
                                           Aspect="AspectFill" 
                                           HorizontalOptions="Fill" 
                                           VerticalOptions="Fill"/>
                                    
                                    <!-- Gradient Overlay for Text Readability -->
                                    <BoxView VerticalOptions="Fill" HorizontalOptions="Fill">
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="Transparent" Offset="0.0" />
                                                <GradientStop Color="#CC000000" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                    
                                    <!-- Content -->
                                    <VerticalStackLayout VerticalOptions="End" Padding="15" Spacing="5">
                                        <Label Text="{Binding Name}" 
                                               FontSize="18" 
                                               FontAttributes="Bold" 
                                               TextColor="White" 
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center">
                                            <Label.Shadow>
                                                <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.8"/>
                                            </Label.Shadow>
                                        </Label>
                                        <Frame BackgroundColor="#D4AF37" CornerRadius="10" Padding="8,2" HorizontalOptions="Center" HasShadow="False" BorderColor="Transparent">
                                            <Label Text="ابدأ الآن" FontSize="10" TextColor="#143214" FontAttributes="Bold"/>
                                        </Frame>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Thikr Detail View -->
        <Grid x:Name="ThikrView" IsVisible="False" RowDefinitions="Auto, *, Auto" BackgroundColor="White">
            <!-- Top Bar -->
            <Grid Padding="15" ColumnDefinitions="Auto, *, Auto, Auto" BackgroundColor="#143214">
                <ImageButton Source="athkar_icon.jpg" Clicked="OnBackToSelection" HeightRequest="24" WidthRequest="24" />
                <Label x:Name="CategoryTitleLabel" Grid.Column="1" Text="القسم" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                
                <HorizontalStackLayout Grid.Column="2" Grid.ColumnSpan="2" Spacing="15" VerticalOptions="Center">
                    <Label x:Name="ListenIconLabel" Text="🔊" FontSize="20" TextColor="White" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnListenClicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <ImageButton Source="quran_icon.jpg" Clicked="OnShareAthkar" HeightRequest="24" WidthRequest="24" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Thikr Content Card -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="25" Spacing="25" VerticalOptions="Center">
                    <Label x:Name="AthkarLabel" 
                           Text="..." 
                           FontSize="22" 
                           TextColor="#143214" 
                           HorizontalTextAlignment="Center" 
                           LineHeight="1.5"/>
                    
                    <Label x:Name="ReferenceLabel" 
                           Text="" 
                           FontSize="14" 
                           TextColor="#2C6E2C" 
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>

                    <Label x:Name="HadithSourceLabel" 
                           Text="" 
                           FontSize="11" 
                           TextColor="#888888" 
                           FontAttributes="Italic"
                           HorizontalTextAlignment="Center"
                           Margin="0,-15,0,0"/>

                    <Frame BackgroundColor="#F0F9F0" CornerRadius="40" HeightRequest="120" WidthRequest="120" HorizontalOptions="Center" Padding="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnIncrementCount"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="CounterLabel" Text="0" FontSize="42" FontAttributes="Bold" TextColor="#143214" HorizontalOptions="Center"/>
                            <Label x:Name="TargetCountLabel" Text="" FontSize="12" TextColor="#2C6E2C" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Label x:Name="ProgressLabel" Text="1 / 1" TextColor="#999999" FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom Navigation -->
            <Grid Grid.Row="2" Padding="20" ColumnDefinitions="*, *" BackgroundColor="#F9F9F9">
                <Button Grid.Column="0" Text="الذكر التالي ➔" x:Name="NextButton" Clicked="OnNextAthkar" 
                        BackgroundColor="#143214" TextColor="White" CornerRadius="15" Margin="5"/>
                <Button Grid.Column="1" Text="تصفير ↺" Clicked="OnResetCounter" 
                        BackgroundColor="#EEEEEE" TextColor="#333333" CornerRadius="15" Margin="5"/>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>