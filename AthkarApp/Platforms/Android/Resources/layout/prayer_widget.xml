<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E6143214"
    android:padding="12dp"
    android:gravity="center">

    <TextView
        android:id="@+id/widget_title_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الصلاة القادمة"
        android:textColor="#D4AF37"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الفجر"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="04:30 AM"
        android:textColor="#CCFFCC"
        android:textSize="16sp"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="متبقي: 01:20:00"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
