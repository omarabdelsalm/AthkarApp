<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/notification_bg_islamic"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- الصف العلوي: العنوان + الأيقونة -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- أيقونة التطبيق -->
        <ImageView
            android:id="@+id/notif_big_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="أذكار" />

        <!-- العنوان الرئيسي -->
        <TextView
            android:id="@+id/notif_big_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/notif_big_icon"
            android:layout_alignParentStart="true"
            android:text="✨ تذكير روحاني — نديّ بذكر الله"
            android:textColor="#D4AF37"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <!-- التصنيف -->
        <TextView
            android:id="@+id/notif_big_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/notif_big_title"
            android:layout_alignParentStart="true"
            android:layout_marginTop="1dp"
            android:text="📿 أذكار المسلم"
            android:textColor="#80D4AF37"
            android:textSize="10sp"
            android:fontFamily="sans-serif" />
    </RelativeLayout>

    <!-- خط فاصل ذهبي رفيع -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#25D4AF37" />

    <!-- نص الذكر الرئيسي -->
    <TextView
        android:id="@+id/notif_big_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="《 سبحان الله وبحمده، سبحان الله العظيم 》"
        android:textColor="#F0F5F0"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:gravity="center"
        android:fontFamily="sans-serif" />

    <!-- نص ذكر فرعي -->
    <TextView
        android:id="@+id/notif_big_subtext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="اللهم صل وسلم على سيدنا محمد"
        android:textColor="#90C8B8"
        android:textSize="11sp"
        android:gravity="center"
        android:fontFamily="sans-serif-light" />

    <!-- سلسلة الأذكار (Streak) -->
    <TextView
        android:id="@+id/notif_big_streak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#D4AF37"
        android:textSize="10sp"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone" />

</LinearLayout>
