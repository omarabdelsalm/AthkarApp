<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- الطبقة الأساسية: تدرج أخضر إسلامي عميق -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF0A3D1A"
                android:centerColor="#FF0D5222"
                android:endColor="#FF073814"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- طبقة نمط هندسي (محاكاة) بتدرج شفاف -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#15D4AF37"
                android:endColor="#05D4AF37"
                android:angle="45"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- حافة ذهبية رفيعة في الأسفل -->
    <item android:bottom="0dp" android:top="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#30D4AF37" />
            <corners android:radius="12dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
